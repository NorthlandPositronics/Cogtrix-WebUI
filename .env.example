# Backend REST base URL. Set to empty string when the WebUI is served behind an
# nginx reverse proxy that forwards /api/* to the backend (the default Docker setup).
# Override with an absolute URL for standalone (non-proxy) deployments.
VITE_API_BASE_URL=http://localhost:8000

# Backend WebSocket base URL. Same origin rules apply as VITE_API_BASE_URL.
# Set to empty string when nginx proxies /ws/* to the backend.
VITE_WS_BASE_URL=ws://localhost:8000
